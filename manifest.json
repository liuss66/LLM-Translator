{
  "manifest_version": 3,
  "name": "LLM Translator",
  "version": "0.3.1",
  "description": "Translate selected text and selected screen regions with OpenAI-compatible or Anthropic models.",
  "permissions": [
    "activeTab",
    "contextMenus",
    "clipboardRead",
    "clipboardWrite",
    "sidePanel",
    "scripting",
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "src/background.js",
    "type": "module"
  },
  "action": {
    "default_title": "LLM Translator",
    "default_popup": "src/popup.html"
  },
  "side_panel": {
    "default_path": "src/sidepanel.html"
  },
  "options_page": "src/options.html",
  "web_accessible_resources": [
    {
      "resources": [
        "src/vendor/katex/fonts/*.woff2"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ],
  "commands": {
    "translate-selection": {
      "suggested_key": {
        "default": "Alt+T"
      },
      "description": "Translate selected text"
    },
    "translate-screenshot-region": {
      "suggested_key": {
        "default": "Alt+S"
      },
      "description": "Select a screen region and translate it"
    },
    "translate-current-page": {
      "suggested_key": {
        "default": "Alt+A"
      },
      "description": "Translate the current visible page"
    },
    "open-side-panel": {
      "suggested_key": {
        "default": "Alt+Shift+Y"
      },
      "description": "Open translator side panel"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "src/vendor/katex/katex.min.js",
        "src/markdown.js",
        "src/content.js"
      ],
      "css": [
        "src/vendor/katex/katex.min.css",
        "src/content.css"
      ],
      "run_at": "document_idle"
    }
  ]
}
